// Prisma schema for ExpertsHub v2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO
}

enum VerificationDocumentType {
  ID_PROOF
  EXPERIENCE_LETTER
  CERTIFICATION
  PORTFOLIO
  ADDRESS_PROOF
}

enum VerificationMediaType {
  VIDEO_INTRO
  PORTFOLIO_IMAGE
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  mobile            String    @unique
  passwordHash      String
  role              Role      @default(CUSTOMER)
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  profilePhotoUrl   String?
  isProfileComplete Boolean   @default(false)
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  lastActiveAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  addresses     Address[]
  workerProfile WorkerProfile?

  bookingsCustomer Booking[] @relation("customerBookings")

  rating       Float @default(0)
  totalReviews Int   @default(0)

  reviewsWritten                 Review[]                        @relation("reviewsWritten")
  reviewsReceived                Review[]                        @relation("reviewsReceived")
  emailVerifications             EmailVerification[]
  passwordResetTokens            PasswordResetToken[]
  workerVerificationApplications WorkerVerificationApplication[]
  payments                       Payment[]
  emergencyContacts              EmergencyContact[]
  notifications                  Notification[]
  pushSubscriptions              PushSubscription[]
  notificationPreference         NotificationPreference?
  sosAlerts                      SOSAlert[]
  customerConversations          Conversation[]                  @relation("CustomerConversations")
  workerConversations            Conversation[]                  @relation("WorkerConversations")
  messages                       Message[]
  statusChanges                  BookingStatusHistory[]
  aiActionAudits                 AIActionAudit[]
  bookingReportsSubmitted        BookingReport[]                  @relation("BookingReportsSubmitted")
  bookingReportsReceived         BookingReport[]                  @relation("BookingReportsReceived")
  bookingReportsReviewed         BookingReport[]                  @relation("BookingReportsReviewedBy")
  invoices                       Invoice[]                       @relation("CustomerInvoices")

  // Business Growth (Sprint 17)
  referralCode   String?             @unique
  referredById   Int?
  referredBy     User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]              @relation("UserReferrals")
  wallet         Wallet?
  transactions   WalletTransaction[]
  walletTopupOrders WalletTopupOrder[]
  favoriteWorkers FavoriteWorker[]
  loyaltyPoints  LoyaltyPoints?
  loyaltyTransactions LoyaltyTransaction[]
  proPlusSubscription ExpertsHubPlusSubscription?

  @@index([deletedAt])
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  token     String   @unique
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model City {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique // URL-friendly name, e.g. "mumbai", "delhi"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services CityService[]
}

model Service {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  description    String?
  category       String?
  basePrice      Decimal?
  commissionRate Float?   @default(15.0) // Platform commission % for this service
  translations   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workers  WorkerService[]
  bookings Booking[]
  cities   CityService[]
}

model CityService {
  cityId    Int
  serviceId Int
  basePrice Decimal? // Overrides service.basePrice if provided
  isActive  Boolean  @default(true) // Can disable certain services in specific cities
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([cityId, serviceId])
}

enum VerificationLevel {
  BASIC
  DOCUMENTS
  VERIFIED
  PREMIUM
}

enum BookingReportCategory {
  SAFETY
  HARASSMENT
  NO_SHOW
  PROPERTY_DAMAGE
  PAYMENT_DISPUTE
  MISCONDUCT
  FRAUD
  OTHER
}

enum BookingReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum BookingReportPriority {
  LOW
  MEDIUM
  HIGH
}

model WorkerProfile {
  id                Int               @id @default(autoincrement())
  userId            Int               @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?
  skills            Json?
  hourlyRate        Decimal?
  rating            Float             @default(0)
  totalReviews      Int               @default(0)
  serviceAreas      Json?
  baseLatitude      Float?
  baseLongitude     Float?
  serviceRadius     Int?              @default(10) // Coverage radius in KM
  isVerified        Boolean           @default(false)
  isProbation       Boolean           @default(true)
  verificationScore Int?
  verificationLevel VerificationLevel @default(BASIC)

  availability   Availability[]
  services       WorkerService[]
  bookingsWorker Booking[]       @relation("bookingsWorker")
  location       WorkerLocation?
  payouts        Payout[]
  favoritedBy    FavoriteWorker[]
  invoices       Invoice[]

  // Payout Details
  bankAccountNumber String?
  bankIfsc          String?
  upiId             String?
  payoutMethod      WorkerPayoutMethod @default(BANK)
  razorpayAccountId String? // Linked account in Razorpay Route
  walletBalance     Decimal @default(0.0) // Pending payout balance
}

model WorkerLocation {
  id              Int           @id @default(autoincrement())
  workerProfileId Int           @unique
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id])
  latitude        Float
  longitude       Float
  isOnline        Boolean       @default(true)
  lastUpdated     DateTime      @default(now())
}

model WorkerVerificationApplication {
  id          Int                @id @default(autoincrement())
  userId      Int
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      VerificationStatus @default(PENDING)
  score       Int?
  notes       String?
  submittedAt DateTime           @default(now())
  reviewedAt  DateTime?

  documents  WorkerVerificationDocument[]
  references WorkerVerificationReference[]
  media      WorkerVerificationMedia[]

  @@index([userId])
  @@index([status])
}

model WorkerVerificationDocument {
  id            Int                           @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationDocumentType
  url           String
  createdAt     DateTime                      @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerVerificationReference {
  id            Int                           @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  relation      String?
  verified      Boolean                       @default(false)
  createdAt     DateTime                      @default(now())

  @@index([applicationId])
  @@index([phone])
}

model WorkerVerificationMedia {
  id            Int                           @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationMediaType
  url           String
  createdAt     DateTime                      @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerService {
  workerId  Int
  serviceId Int
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
  @@index([serviceId])
}

model Availability {
  id        Int           @id @default(autoincrement())
  workerId  Int
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0-6 (Sun-Sat)
  startTime String // HH:mm
  endTime   String // HH:mm
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([workerId, dayOfWeek, startTime, endTime])
}

model Booking {
  id                         Int            @id @default(autoincrement())
  customerId                 Int
  customer                   User           @relation("customerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  workerProfileId            Int?
  workerProfile              WorkerProfile? @relation("bookingsWorker", fields: [workerProfileId], references: [id], onDelete: Cascade)
  offeredToWorkerId          Int?
  serviceId                  Int
  service                    Service        @relation(fields: [serviceId], references: [id])
  scheduledAt                DateTime
  status                     BookingStatus  @default(PENDING)
  paymentStatus              PaymentStatus  @default(PENDING)
  paymentReference           String?
  paidAt                     DateTime?
  totalPrice                 Decimal?
  basePrice                  Decimal? // Raw cost
  timeMultiplier             Float?         @default(1.0)
  surgeMultiplier            Float?         @default(1.0)
  urgencyMultiplier          Float?         @default(1.0)
  workerTierMultiplier       Float?         @default(1.0)
  distanceSurcharge          Decimal?       @default(0.0)
  gstAmount                  Decimal?       @default(0.0) // 18% GST
  platformCommission         Decimal? // Platform's cut
  workerPayoutAmount         Decimal? // Worker's cut (totalPrice - commission)
  address                    String?
  latitude                   Float?
  longitude                  Float?
  notes                      String?
  estimatedDuration          Int? // Duration in minutes (default: 120 if not provided)
  cancellationReason         String?
  cancellationPenaltyPercent Int? // 0=free, 25/50/100 = penalty %

  // OTP Verification Fields
  startOtp       String? // 4-digit code
  completionOtp  String? // 4-digit code (for job completion if needed)
  otpGeneratedAt DateTime?
  startedAt      DateTime? // When job actually started (OTP verified)
  completedAt    DateTime? // When job was marked complete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  couponId     Int?
  coupon       Coupon?  @relation("BookingCoupons", fields: [couponId], references: [id])
  couponAmount Decimal? @default(0.0) // Discount amount subtracted from price

  reviews       Review[]
  payments      Payment[]
  photos        BookingPhoto[]
  sosAlerts     SOSAlert[]
  bookingReports BookingReport[]
  conversation  Conversation?
  sessions      BookingSession[]
  statusHistory BookingStatusHistory[]
  invoice       Invoice?

  // Recurring Bookings (Sprint 17 - #78)
  frequency    BookingFrequency @default(ONE_TIME)

  @@index([status])
  @@index([customerId])
  @@index([workerProfileId])
  @@index([scheduledAt])
  @@index([paymentStatus])
}

model Payment {
  id         Int           @id @default(autoincrement())
  bookingId  Int
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId Int
  customer   User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Decimal?
  status     PaymentStatus @default(PENDING)
  reference  String?
  createdAt  DateTime      @default(now())

  @@index([bookingId])
  @@index([customerId])
}

model Review {
  id        Int     @id @default(autoincrement())
  bookingId Int
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  reviewerId Int
  reviewer   User @relation("reviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)

  revieweeId Int
  reviewee   User @relation("reviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?
  reviewerIp String? // Fraud detection: IP tracking
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, reviewerId])
  @@index([bookingId])
  @@index([reviewerId])
  @@index([revieweeId])
}

model BookingPhoto {
  id        Int       @id @default(autoincrement())
  bookingId Int
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url       String
  type      PhotoType
  caption   String?
  createdAt DateTime  @default(now())
}

enum PhotoType {
  BEFORE
  AFTER
}

model EmergencyContact {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  phone    String
  relation String // "Parent", "Spouse", "Friend"
}

model SOSAlert {
  id              Int       @id @default(autoincrement())
  bookingId       Int
  booking         Booking   @relation(fields: [bookingId], references: [id])
  triggeredBy     Int
  triggeredByUser User      @relation(fields: [triggeredBy], references: [id], onDelete: Cascade)
  latitude        Float?
  longitude       Float?
  status          SOSStatus @default(ACTIVE)
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([triggeredBy])
}

enum SOSStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

model BookingReport {
  id             Int                   @id @default(autoincrement())
  bookingId      Int
  booking        Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporterId     Int
  reporter       User                  @relation("BookingReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId Int
  reportedUser   User                  @relation("BookingReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reportedRole   Role
  category       BookingReportCategory
  status         BookingReportStatus    @default(OPEN)
  priority       BookingReportPriority  @default(MEDIUM)
  details        String                @db.Text
  evidenceUrl    String?
  adminNotes     String?               @db.Text
  reviewedById   Int?
  reviewedBy     User?                 @relation("BookingReportsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([bookingId])
  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "BOOKING_UPDATE", "REVIEW_RECEIVED", "PAYMENT", "SYSTEM"
  title     String
  message   String
  data      Json? // Extra context like { bookingId: 5 }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([userId, read])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String // Public key for push encryption
  auth      String // Auth secret for push encryption
  userAgent String? // Browser/device info for management
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Channel toggles
  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)

  // Event-level toggles
  bookingUpdates Boolean @default(true)
  reviewAlerts   Boolean @default(true)
  paymentAlerts  Boolean @default(true)
  chatMessages   Boolean @default(true)
  promotions     Boolean @default(false) // Off by default — opt-in
  systemAlerts   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        Int      @id @default(autoincrement())
  bookingId Int?     @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])

  // Members
  customerId   Int
  customer     User @relation("CustomerConversations", fields: [customerId], references: [id])
  workerUserId Int
  worker       User @relation("WorkerConversations", fields: [workerUserId], references: [id])

  messages      Message[]
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([workerUserId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User         @relation(fields: [senderId], references: [id])
  content        String?      @db.Text
  type           MessageType  @default(TEXT)
  mediaUrl       String?
  fileName       String?
  fileSize       Int?
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
}

model BookingSession {
  id          Int       @id @default(autoincrement())
  bookingId   Int
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sessionDate DateTime
  startTime   DateTime?
  endTime     DateTime?
  isActive    Boolean   @default(false)
  startOtp    String?
  otpVerified Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([bookingId])
  @@index([sessionDate])
}

model BookingStatusHistory {
  id         Int            @id @default(autoincrement())
  bookingId  Int
  booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus BookingStatus?
  toStatus   BookingStatus?
  changedBy  Int?
  user       User?          @relation(fields: [changedBy], references: [id], onDelete: Cascade)
  reason     String?
  createdAt  DateTime       @default(now())

  @@index([bookingId])
  @@index([changedBy])
}

model AIActionAudit {
  id                   Int      @id @default(autoincrement())
  userId               Int
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                 Role
  sessionId            String
  channel              String   @default("CHAT")
  intent               String
  action               String?
  requiresConfirmation Boolean  @default(false)
  status               String   @default("SUCCESS")
  requestText          String?  @db.Text
  requestData          Json?
  responseText         String?  @db.Text
  responseData         Json?
  error                String?
  durationMs           Int?
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([intent, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Payout {
  id                Int           @id @default(autoincrement())
  workerProfileId   Int
  workerProfile     WorkerProfile @relation(fields: [workerProfileId], references: [id])
  amount            Decimal
  status            PayoutStatus  @default(PENDING)
  transferReference String?
  processedAt       DateTime?
  createdAt         DateTime      @default(now())

  @@index([workerProfileId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum WorkerPayoutMethod {
  BANK
  UPI
  LINKED_ACCOUNT
}
// ── BUSINESS GROWTH MODELS (Sprint 17) ───────────────────────────

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0.0) @db.Decimal(10, 2)
  currency  String   @default("INR")
  updatedAt DateTime @updatedAt
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  REFERRAL_BONUS
  REWARD_CREDIT
}

enum WalletTopupStatus {
  CREATED
  PAID
  FAILED
}

model WalletTransaction {
  id          Int                   @id @default(autoincrement())
  userId      Int
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal               @db.Decimal(10, 2)
  type        WalletTransactionType
  description String?
  referenceId String?               // e.g., booking ID or coupon code
  status      String                @default("COMPLETED") // PENDING, COMPLETED, FAILED
  createdAt   DateTime              @default(now())

  @@index([userId, createdAt])
}

model WalletTopupOrder {
  id                Int              @id @default(autoincrement())
  userId            Int
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Decimal          @db.Decimal(10, 2)
  currency          String           @default("INR")
  status            WalletTopupStatus @default(CREATED)
  razorpayOrderId   String           @unique
  razorpayPaymentId String?          @unique
  razorpaySignature String?
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}

model Coupon {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  discountType    String    // PERCENTAGE or FIXED
  discountValue   Decimal   @db.Decimal(10, 2)
  minOrderValue   Decimal?  @db.Decimal(10, 2)
  maxDiscount     Decimal?  @db.Decimal(10, 2)
  isActive        Boolean   @default(true)
  startDate       DateTime?
  endDate         DateTime?
  usageLimit      Int?
  usageCount      Int       @default(0)
  applicableTo    String?   // e.g., category name or "ALL"
  firstTimeOnly   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  bookings        Booking[] @relation("BookingCoupons")
}

// Update Booking to support Coupons
// Need to add many-to-many or one-to-many? Usually one coupon per booking.
// Let's add it to Booking model separately.

// ── FAVORITE WORKER (Sprint 17 - #80) ────────────────────────────

model FavoriteWorker {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerProfileId Int
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, workerProfileId])
  @@index([userId])
  @@index([workerProfileId])
}

// ── LOYALTY POINTS (Sprint 17 - #75) ─────────────────────────────

model LoyaltyPoints {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)    // Current redeemable points
  lifetime  Int      @default(0)    // Total points ever earned
  updatedAt DateTime @updatedAt
}

model LoyaltyTransaction {
  id          Int                  @id @default(autoincrement())
  userId      Int
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int                  // Positive = earned, Negative = redeemed/expired
  type        LoyaltyTransactionType
  description String?
  referenceId String?              // e.g., booking ID
  expiresAt   DateTime?            // Points expire after 6 months
  createdAt   DateTime             @default(now())

  @@index([userId])
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
}

// ── ExpertsHub PLUS SUBSCRIPTION (Sprint 17 - #74) ─────────────────

model ExpertsHubPlusSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startDate DateTime @default(now())
  endDate   DateTime // Typically 1 year or 1 month from startDate
  planId    String   // Identifier for the subscription tier (e.g. 'plus_monthly', 'plus_yearly')
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model GiftCard {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  balance     Decimal  @db.Decimal(10, 2)
  initialValue Decimal @db.Decimal(10, 2)
  senderName  String?
  recipientEmail String
  message     String?
  expiryDate  DateTime
  isRedeemed  Boolean  @default(false)
  redeemedBy  Int?     // User ID who redeemed it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

enum BookingFrequency {
  ONE_TIME
  WEEKLY
  BI_WEEKLY
  MONTHLY
}

model DailyActivity {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @default(now())
  dauCount  Int      @default(0) // Daily Active Users
  mauCount  Int      @default(0) // Monthly Active Users
  userList  Int[]    // List of user IDs active today
  createdAt DateTime @default(now())
}

model FraudAlert {
  id          Int            @id @default(autoincrement())
  type        FraudAlertType
  severity    String         @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  description String
  bookingId   Int?
  userId      Int?
  data        Json?
  resolved    Boolean        @default(false)
  createdAt   DateTime       @default(now())

  @@index([type])
  @@index([userId])
}

model Invoice {
  id               Int      @id @default(autoincrement())
  bookingId        Int      @unique
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId       Int
  customer         User     @relation("CustomerInvoices", fields: [customerId], references: [id])
  workerProfileId  Int?
  workerProfile    WorkerProfile? @relation(fields: [workerProfileId], references: [id], onDelete: SetNull)
  
  amount           Decimal
  platformCut      Decimal
  workerCut        Decimal
  
  invoiceNumber    String   @unique
  invoiceDate      DateTime @default(now())
  dueDate          DateTime?
  status           InvoiceStatus @default(GENERATED)
  
  pdfUrl           String?  // S3 or Cloudinary URL
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([customerId])
  @@index([workerProfileId])
  @@index([status])
  @@index([invoiceDate])
}

enum InvoiceStatus {
  GENERATED
  SENT
  VIEWED
  PAID
  CANCELLED
}

enum FraudAlertType {
  FAKE_REVIEW
  NO_SHOW_GPS
  SUSPICIOUS_VELOCITY
  PAYMENT_CHARGEBACK
}

