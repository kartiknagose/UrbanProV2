# Server environment template (safe to commit)
# Copy this file to server/.env for local development.
# For production, use the same keys in Render environment variables.

########################################
# Runtime
########################################
# Local: development. Production: production.
NODE_ENV=development
PORT=3000

########################################
# Core infrastructure
########################################
# Local example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ExpertsHub_v2?schema=public&connection_limit=20&pool_timeout=30
# Production example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:ENCODED_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Local example:
# DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5432/ExpertsHub_v2?schema=public
# Production example:
# DIRECT_DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=

# Local: optional and can be empty.
# Production: set to your Upstash Redis rediss URL.
REDIS_URL=

########################################
# Auth, security, and cookies (REQUIRED)
########################################
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=expertshub
JWT_AUDIENCE=expertshub-users

REQUIRE_EMAIL_VERIFICATION=true

# Local: comma-separated list of localhost origins.
# Production: set to your deployed frontend domain.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Optional cookie domain for local testing.
COOKIE_DOMAIN=
AUTH_COOKIE_MAX_AGE_MS=86400000

########################################
# AI agent layer (REQUIRED for /api/ai/chat)
########################################
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GROQ_TIMEOUT_MS=20000
INTERNAL_API_BASE_URL=http://127.0.0.1:3000
AI_TOOL_TIMEOUT_MS=12000

########################################
# Optional AI voice/chat provider settings
########################################
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_STT_PROVIDER=auto
OPENAI_STT_MODEL=whisper-1
GEMINI_STT_MODEL=gemini-2.0-flash
AI_CHAT_PROVIDER=auto
AI_BOT_NAME=Alex
GEMINI_CHAT_MODEL=gemini-2.0-flash
OPENAI_CHAT_MODEL=gpt-4o-mini
AI_CHAT_TEMPERATURE=0.4
AI_CHAT_MAX_TOKENS=900
AI_CHAT_TIMEOUT_MS=30000
AI_VOICE_MAX_BYTES=15728640

########################################
# Email delivery
########################################
# If using Resend in production, set SMTP_DISABLED=true and fill RESEND_* values.
SMTP_DISABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_SEND_TIMEOUT_MS=20000
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_VERIFY_TIMEOUT_MS=12000

FROM_EMAIL=
FROM_NAME=ExpertsHub

RESEND_API_KEY=
RESEND_FROM=
RESEND_HTTP_TIMEOUT_MS=10000

SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_HTTP_TIMEOUT_MS=10000

EMAIL_HEALTH_TOKEN=
EMAIL_HEALTH_PROBE_PUBLIC=false

########################################
# Payments, payouts, uploads, push, maps
########################################
# Razorpay uses the same env names for test and live mode.
# Localhost: use Razorpay TEST keys.
# Production: use Razorpay LIVE keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Keep simulated payouts in local/dev unless you are explicitly testing live transfers.
RAZORPAY_PAYOUT_MODE=SIMULATED

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@expertshub.tech

GOOGLE_GEOCODING_API_KEY=

########################################
# Observability and cache-relay (optional)
########################################
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Only required if you enable those integrations locally or in production.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CACHE_RELAY_SECRET=
