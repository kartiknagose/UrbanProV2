# Server environment template (safe to commit)
# Copy to .env for local development and fill with real values.

NODE_ENV=development
PORT=3000

# Local Postgres (docker-compose default)
DATABASE_URL="postgresql://postgres:password@localhost:5432/urbanpro_v2?schema=public"

# Local Redis
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET=replace-with-long-random-secret
REQUIRE_EMAIL_VERIFICATION=false

# Frontend URLs
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Supabase (optional for local; required in production)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CACHE_RELAY_SECRET=
CACHE_RELAY_URL=

# SMTP (required for production signup verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_SEND_TIMEOUT_MS=20000
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_VERIFY_TIMEOUT_MS=12000
# Optional HTTPS fallback for hosts where outbound SMTP is blocked
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_HTTP_TIMEOUT_MS=10000
# Optional: skip SMTP entirely and use fallback provider directly
SMTP_DISABLED=false
# Optional: protect /health/email endpoint in production
EMAIL_HEALTH_TOKEN=mailcheck123
# Optional: set true to temporarily allow /health/email without token in production
EMAIL_HEALTH_PROBE_PUBLIC=false
# Optional aliases supported by code:
# SMTP_PASSWORD= / MAIL_PASS= / MAIL_PASSWORD= / EMAIL_PASS= / GMAIL_APP_PASSWORD=
# Gmail requirement: use a 16-character App Password (spaces are allowed when copying; code strips them)
FROM_EMAIL=noreply@urbanpro.com
FROM_NAME=UrbanPro

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_MODE=SIMULATED

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@urbanpro.com

# Geocoding
GOOGLE_GEOCODING_API_KEY=
