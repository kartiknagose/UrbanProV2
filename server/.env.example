# Server environment template (safe to commit)
# Copy to .env for local development and fill with real values.

NODE_ENV=development
PORT=3000

# Local Postgres (docker-compose default)
DATABASE_URL="postgresql://postgres:password@localhost:5432/urbanpro_v2?schema=public"

# Local Redis
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET=replace-with-long-random-secret
REQUIRE_EMAIL_VERIFICATION=true

# Frontend URLs
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# SMTP for local email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_SEND_TIMEOUT_MS=20000
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_VERIFY_TIMEOUT_MS=12000
SMTP_DISABLED=false
FROM_EMAIL=
FROM_NAME=UrbanPro

# Resend (recommended for production delivery)
# Create API key at https://resend.com/api-keys
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, e.g. no-reply@expertshub.tech
RESEND_FROM=
RESEND_HTTP_TIMEOUT_MS=10000

# Optional secondary provider fallback
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_HTTP_TIMEOUT_MS=10000

# Optional health endpoint token (for /health/email and /health/email/send-test)
EMAIL_HEALTH_TOKEN=
EMAIL_HEALTH_PROBE_PUBLIC=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_MODE=SIMULATED

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@urbanpro.com

# Geocoding
GOOGLE_GEOCODING_API_KEY=
