# Copy this file to .env before running: docker compose --env-file .env up -d --build

# Database
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_NAME=ExpertsHub_v2

# Core app
JWT_SECRET=change-me-very-long-random-secret
CORS_ORIGIN=http://localhost
FRONTEND_URL=http://localhost

# Frontend build/runtime
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_RAZORPAY_KEY_ID=
VITE_GOOGLE_PLACES_API_KEY=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=ExpertsHub

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional unless payments enabled)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_MODE=SIMULATED

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@expertshub.tech

# Maps (optional)
GOOGLE_GEOCODING_API_KEY=

# AI Agent layer
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GROQ_TIMEOUT_MS=20000
AI_TOOL_TIMEOUT_MS=12000
AI_VOICE_MAX_BYTES=15728640

# Internal service URL for agent tools
INTERNAL_API_BASE_URL=http://127.0.0.1:5000
