# Client environment template (safe to commit)
# Copy this file to client/.env for local development.
# For production, set the same keys in Vercel environment variables.

# Core API/runtime
# Local: use localhost.
# Production: use your Render backend URL.
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_API_TIMEOUT_MS=15000
VITE_APP_ENV=development

# Build/runtime injection helper (optional; JSON string)
# Example: {"VITE_API_URL":"https://api.example.com/api"}
VITE_ENV=

# Feature integrations (optional)
# Razorpay checkout will work in test mode once you place the TEST publishable key here.
VITE_RAZORPAY_KEY_ID=
VITE_GOOGLE_PLACES_API_KEY=

# Monitoring (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional Supabase client-side integration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_FUNCTIONS_URL=

# Build flag for vite PWA plugin
VITE_PWA_DISABLED=false
